{
    "name": "IS2-Lab07 - Pruebas Unitarias",
    "image": "mcr.microsoft.com/devcontainers/java:1-21-bookworm",
    "features": {
        "ghcr.io/devcontainers/features/maven:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "vscjava.vscode-java-pack",
                "vscjava.vscode-maven"
            ]
        }
    },
    "postCreateCommand": "java -version && mvn -version && mvn -q -DskipTests dependency:go-offline"
}